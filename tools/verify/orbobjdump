#!/usr/bin/env bash
# ARM objdump launcher (GNU binutils, in the OrbStack `ubuntu` machine).
# Fully supports ARMv7-A Thumb-2 + VFP/NEON, unlike objdiff's ARM backend.
# Used by tools/verify/asmdiff.py. Override the machine with GOF2_ORB_MACHINE.
set -euo pipefail
MACHINE="${GOF2_ORB_MACHINE:-ubuntu}"
# stdin from /dev/null: objdump reads none, and it stops `orb` from flipping the shared
# controlling TTY to raw mode (the parallel disassemble jobs race to restore it and leave the
# terminal raw, which staircases the report output).
exec orb -m "$MACHINE" arm-linux-gnueabihf-objdump "$@" </dev/null
