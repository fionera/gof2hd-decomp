#!/usr/bin/env bash
# Matching C++ compiler launcher: runs the NDK r18b clang++ inside the OrbStack
# `ubuntu` machine. OrbStack mirrors the macOS filesystem 1:1, so all path
# arguments (sources, -I, -o, --sysroot) pass through unchanged.
#
# Used as CMAKE_CXX_COMPILER by cmake/orbstack-ndk-arm.toolchain.cmake and by
# tools/verify/build_objs.sh. Override the machine with GOF2_ORB_MACHINE.
set -euo pipefail
MACHINE="${GOF2_ORB_MACHINE:-ubuntu}"
NDK="${NDK:-/opt/android-ndk-r18b}"
CLANGXX="$NDK/toolchains/llvm/prebuilt/linux-x86_64/bin/clang++"
# stdin from /dev/null: clang reads none, and it stops `orb` from treating the shared
# controlling TTY as interactive (it flips it to raw mode and races to restore it across the
# parallel build jobs, which leaves the terminal raw and staircases the report output).
exec orb -m "$MACHINE" "$CLANGXX" "$@" </dev/null
