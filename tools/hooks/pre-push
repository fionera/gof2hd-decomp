#!/bin/sh
# pre-push -- run the no-degradation ratchet before anything leaves this machine.
# Installed via:  git config core.hooksPath tools/hooks
# Bypass (emergencies only, explain in the commit message):  git push --no-verify
cd "$(git rev-parse --show-toplevel)" || exit 1
echo "pre-push: running the no-degradation ratchet (tools/ratchet.py) ..."
exec python3 tools/ratchet.py
